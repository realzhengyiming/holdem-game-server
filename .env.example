# 复制为 .env 后填写；服务器启动时会自动读取。
# 不配置 SMTP_HOST 时，验证码不会真的发邮件，只会在本地页面/服务端日志显示。

HOST=127.0.0.1
PORT=3001
NODE_ENV=development

# 邮箱验证码 SMTP 配置示例
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your-account@example.com
SMTP_PASS=your-smtp-authorization-code
SMTP_FROM=your-account@example.com
# 465 端口通常设为 true；587 通常保持 false 或不填
SMTP_SECURE=false
SMTP_TIMEOUT_MS=12000

# 可选：交互冷却
EMOTE_COOLDOWN_MS=2500
CHAT_COOLDOWN_MS=3000
DEALER_TIP_COOLDOWN_MS=2000
